{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skills Data Schema",
  "type": "object",
  "required": ["skills"],
  "properties": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "stage", "author", "usageCommand", "lastUpdated", "gitUrl"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^skill-[a-z0-9-]+$",
            "description": "ASCII ID，格式: skill-xxx"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Skill名称"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "功能简介"
          },
          "stage": {
            "type": "string",
            "enum": ["需求阶段", "设计阶段", "编码阶段", "测试阶段", "部署阶段"],
            "description": "开发阶段分类"
          },
          "author": {
            "type": "string",
            "minLength": 1,
            "description": "作者姓名"
          },
          "version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
            "description": "版本号，格式: v1.0.0"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "标签列表"
          },
          "usageCommand": {
            "type": "string",
            "minLength": 1,
            "description": "使用命令模板"
          },
          "usageCommandExample": {
            "type": "string",
            "description": "使用命令示例"
          },
          "lastUpdated": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
            "description": "最后更新日期，格式: YYYY-MM-DD"
          },
          "gitUrl": {
            "type": "string",
            "pattern": "^https?://.+$",
            "description": "Git仓库URL"
          },
          "isRecommended": {
            "type": "boolean",
            "description": "是否推荐"
          },
          "recommendOrder": {
            "type": "integer",
            "minimum": 1,
            "description": "推荐排序（仅isRecommended=true时有效）"
          }
        }
      }
    }
  }
}